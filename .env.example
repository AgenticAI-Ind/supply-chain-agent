# Application Settings
APP_NAME="Supply Chain & Logistics Agent"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production
API_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=False

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supply_chain
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
CACHE_TTL=3600

# External API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
FEDEX_API_KEY=your_fedex_api_key_here
FEDEX_API_SECRET=your_fedex_api_secret_here
UPS_API_KEY=your_ups_api_key_here
UPS_API_SECRET=your_ups_api_secret_here
DHL_API_KEY=your_dhl_api_key_here

# ML Model Configuration
MODEL_DIR=./models
PROPHET_MODEL_PATH=./models/prophet
LSTM_MODEL_PATH=./models/lstm
RISK_MODEL_PATH=./models/risk_assessment
MODEL_VERSION=1.0.0

# Forecasting Configuration
DEFAULT_FORECAST_HORIZON=30
MIN_HISTORICAL_DATA_POINTS=30
MAX_FORECAST_HORIZON=365

# Route Optimization Configuration
DEFAULT_VEHICLE_SPEED_KMH=60.0
FUEL_COST_PER_KM=0.15
VEHICLE_COST_PER_HOUR=25.0
MAX_ROUTE_OPTIMIZATION_TIME_MS=30000

# Inventory Management Configuration
DEFAULT_SERVICE_LEVEL=0.95
DEFAULT_HOLDING_COST_PERCENTAGE=0.25
DEFAULT_ORDERING_COST=50.0
SAFETY_STOCK_Z_SCORE=1.645

# Security
SECRET_KEY=change-me-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# CORS Configuration
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Monitoring
METRICS_ENABLED=True
SENTRY_DSN=
